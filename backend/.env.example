# ============================================================
# ERP 后端环境变量模板
# 复制本文件为 .env 并填入真实值：
#   cp .env.example .env
# ============================================================

# ── Django 核心 ──
DEBUG=False
DEMO_MODE=False
DJANGO_SECRET_KEY=请替换为一个 64 位随机字符串（可用 python -c "import secrets; print(secrets.token_urlsafe(48))" 生成）
ALLOWED_HOSTS=127.0.0.1,localhost,你的域名.com

# ── MySQL 数据库 ──
MYSQL_DATABASE=sku_db
MYSQL_USER=your_db_user
MYSQL_PASSWORD=your_strong_db_password
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
# 连接池最大存活秒数（0=每次请求新建连接）
DB_CONN_MAX_AGE=120

# ── Redis（缓存 / Channels / Celery Broker） ──
REDIS_URL=redis://127.0.0.1:6379/1
CHANNEL_REDIS_URL=redis://127.0.0.1:6379/2

# ── 降级开关（生产环境 Redis 可达时设为 false） ──
CACHE_FAILOPEN_LOCMEM=false
DB_FAILOPEN_SQLITE=false

# ── Celery 任务队列 ──
CELERY_TASK_ALWAYS_EAGER=False

# ── CORS 跨域 ──
CORS_ALLOW_ALL_ORIGINS=false
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://你的前端域名.com
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://你的前端域名.com

# ── TikTok Shop ──
TIKTOK_CLIENT_KEY=你的TikTok App Key
TIKTOK_CLIENT_SECRET=你的TikTok App Secret
TIKTOK_REDIRECT_URI=http://localhost:5174/api/shop/tiktok/callback

# ── 短信服务（阿里云） ──
SMS_PROVIDER=aliyun
ALIYUN_ACCESS_KEY_ID=你的阿里云 AccessKey
ALIYUN_ACCESS_KEY_SECRET=你的阿里云 AccessSecret
ALIYUN_SMS_SIGN_NAME=你的短信签名
ALIYUN_SMS_TEMPLATE_CODE=你的短信模板Code

# ── 加 / 解密密钥（Token 存储用） ──
FERNET_KEY=请用 python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())" 生成

# ── 物流追踪 ──
LOGISTICS_AGGREGATOR_PROVIDER=17track
TRACK17_API_KEY=你的17Track API Key
KUAIDI100_API_KEY=你的快递100 Key

# ── RBAC 权限控制 ──
RBAC_ENFORCE=true
OPS_ADMIN_USERNAMES=admin

# ── 日志 ──
LOG_LEVEL=INFO
AUTH_AUDIT_LOG_FILE=logs/auth_audit.log
