# ── Docker Compose 环境变量 ─────────────────────────────
# 与 docker-compose.yml 配合使用，首次使用请复制为 .env
# cp .env.example .env

# 端口映射
ERP_FRONTEND_PORT=1101
ERP_BACKEND_PORT=1102
ERP_MYSQL_PORT=1103
ERP_REDIS_PORT=1104

# MySQL 初始配置
MYSQL_ROOT_PASSWORD=root_dev_only
MYSQL_DATABASE=sku_db
MYSQL_USER=erp
MYSQL_PASSWORD=erp_dev_pass

# Redis
REDIS_PASSWORD=

# 服务器域名（本地开发留空）
DOMAIN=www.tuoyue-tch.com

# Django
DJANGO_SECRET_KEY=dev-secret-key-change-in-production
DEBUG=True
DEMO_MODE=True
